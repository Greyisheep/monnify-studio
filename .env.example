# Monnify Studio - environment template.
#
#   cp .env.example .env   then fill in only what you want.
#
# EVERYTHING here is optional. `docker compose up` works with this file empty
# (Moni routes by keyword, orders run on the mock adapter, tests pass keyless).
# Keys only UNLOCK live features. Sandbox only - production execution is refused.
# Never commit your real .env.

# --- AI: pick one provider so Moni composes from free text (else keyword routing)
# AI_PROVIDER selects which runs: anthropic | openai | google
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Monnify sandbox: real checkout + verification + disbursement
# Get these at https://app.monnify.com -> sandbox -> API keys.
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WALLET_ACCOUNT=        # source wallet for real payouts (optional)

# --- Email receipts (ZeptoMail transactional API, not SMTP)
# ZEPTOMAIL_API_KEY is the FULL Authorization value incl. prefix, e.g.
#   Zoho-enczapikey <token>
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_SENDER=
ZEPTOMAIL_REPLY_TO=

# --- WhatsApp nudges (Evolution API). Leave blank to no-op.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- Demo notification target: where a flow's notify block sends when the node
# names no recipient (so the demo notification lands somewhere you can see it).
STUDIO_NOTIFY_NUMBER=          # e.g. 08110774138
STUDIO_NOTIFY_EMAIL=           # e.g. you@example.com
