# Monnify Studio - environment template. Copy to .env and fill in.
# NEVER commit .env. Sandbox keys only. Studio disables production execution.

# --- Monnify sandbox credentials (get at https://app.monnify.com) ---
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://sandbox.monnify.com

# --- Backend ---
DATABASE_URL=postgresql+psycopg://studio:studio@localhost:5432/monnify_studio
STUDIO_ENV=development
# Hard guard: production execution is refused unless explicitly enabled (never in the challenge build)
ALLOW_PRODUCTION_EXECUTION=false

# --- Web (apps/web/.env.local) ---
# Browser-visible API origin. Prefer 8010 so it does not collide with other local :8000 services.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8010

# --- AI (Epic 3): system supports the top 3 providers; tester picks one (D16) ---
# AI_PROVIDER selects which one runs: anthropic | openai | google (default anthropic)
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Observability (D15) ---
# Leave the OTLP endpoint blank to log/trace to console only.
# Set it to a collector (e.g. http://localhost:4318) to ship traces out.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=monnify-studio
