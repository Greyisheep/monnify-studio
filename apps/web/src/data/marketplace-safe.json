    "monnify.query_transfer_status": { "type": "monnify.query_transfer_status", "category": "monnify", "title": "Query Transfer Status" },
    "safety.audit_event": { "type": "safety.audit_event", "category": "safety", "title": "Audit Event" },
    "event.scheduled": { "type": "event.scheduled", "category": "event", "title": "Scheduled Trigger" },
    "safety.reconciliation": { "type": "safety.reconciliation", "category": "safety", "title": "Reconciliation" }
