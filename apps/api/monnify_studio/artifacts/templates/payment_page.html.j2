<!doctype html>
{# The seller's payment page (#52, D17). Structure is generated; look comes
   from skin.css.j2 (#59 item 1). The Pay button creates a REAL sandbox
   checkout via POST /preview/{artifact_id}/pay. #}
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ config.business_name }} | Pay securely</title>
  <link rel="stylesheet" href="/preview/{{ artifact_id }}/skin.css" />
</head>
<body>
  <main class="page">
    <header class="brand">
      {% if config.logo_url %}
      <img class="brand-logo" src="{{ config.logo_url }}" alt="{{ config.business_name }} logo" />
      {% else %}
      <div class="brand-mark" aria-hidden="true">{{ config.business_name[:1] }}</div>
      {% endif %}
      <div>
        <h1>{{ config.business_name }}</h1>
        <p class="tagline">{{ config.tagline }}</p>
      </div>
    </header>

    <section class="card product">
      <h2>{{ config.product_name }}</h2>
      <p class="price"><span class="naira">NGN</span> {{ price_display }}</p>
      <button id="pay" class="btn-primary" type="button">Pay now</button>
      <button id="claim" class="btn-ghost claim" type="button" hidden>
        I have sent the money
      </button>
      <p id="status" class="status" role="status"></p>
      <p class="trust">
        <span class="dot" aria-hidden="true"></span>
        Payments verified server-side with Monnify. A transfer screenshot is
        never enough to mark an order paid.
      </p>
    </section>

    <footer class="foot">
      <a href="/preview/{{ artifact_id }}/dashboard">Seller dashboard</a>
      <span>Generated by Monnify Studio</span>
    </footer>
  </main>

  <script>
    const btn = document.getElementById("pay");
    const claim = document.getElementById("claim");
    const status = document.getElementById("status");
    let orderRef = null;

    btn.addEventListener("click", async () => {
      btn.disabled = true;
      status.textContent = "Creating secure checkout...";
      try {
        const res = await fetch("/preview/{{ artifact_id }}/pay", { method: "POST" });
        if (!res.ok) throw new Error((await res.json()).detail || "checkout failed");
        const data = await res.json();
        orderRef = data.order_reference;
        status.textContent = "Opening Monnify checkout (order " + orderRef + ")";
        claim.hidden = false;
        window.open(data.checkout_url, "_blank", "noopener");
      } catch (err) {
        status.textContent = "Could not start checkout: " + err.message;
      } finally {
        btn.disabled = false;
      }
    });

    // The fake-credit-alert trust boundary (#53): claiming payment only
    // triggers a server-side check with Monnify; it never marks anything paid.
    claim.addEventListener("click", async () => {
      if (!orderRef) return;
      claim.disabled = true;
      status.textContent = "Checking with Monnify...";
      try {
        const res = await fetch(
          "/preview/{{ artifact_id }}/orders/" + orderRef + "/verify",
          { method: "POST" },
        );
        if (!res.ok) throw new Error((await res.json()).detail || "verify failed");
        const order = await res.json();
        status.textContent = order.status === "verified"
          ? "Payment confirmed. Thank you!"
          : "We checked with Monnify: " + order.note + ".";
      } catch (err) {
        status.textContent = "Could not verify: " + err.message;
      } finally {
        claim.disabled = false;
      }
    });
  </script>
</body>
</html>
