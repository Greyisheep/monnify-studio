<!doctype html>
{# The buyer-facing invoice page (#85, D17). Same trust boundary as the shop:
   "Pay now" opens a real sandbox checkout; "I have sent the money" only asks
   Monnify for the truth. Settlement note names the merchant's Monnify
   (Moniepoint) account. #}
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Invoice {{ invoice.reference }} | {{ config.business_name }}</title>
  <link rel="stylesheet" href="/preview/{{ artifact_id }}/skin.css" />
</head>
<body>
  <main class="page">
    <header class="brand">
      {% if config.logo_url %}
      <img class="brand-logo" src="{{ config.logo_url }}" alt="{{ config.business_name }} logo" />
      {% else %}
      <div class="brand-mark" aria-hidden="true">{{ config.business_name[:1] }}</div>
      {% endif %}
      <div>
        <h1>{{ config.business_name }}</h1>
        <p class="tagline">Invoice {{ invoice.reference }}</p>
      </div>
    </header>

    <section class="card product">
      <h2>Billed to: {{ invoice.customer or "Customer" }}</h2>
      <p class="tagline">{{ invoice.description or invoice.product }}</p>
      <div class="price"><span class="naira">NGN</span> {{ amount_display }}</div>

      {% if invoice.status.value == "verified" %}
      <p><span class="badge ok">Paid and verified</span></p>
      {% else %}
      <button id="pay" class="btn-primary" type="button">Pay now</button>
      <button id="claim" class="btn-ghost claim" type="button">
        I have sent the money
      </button>
      <p id="status" class="status"></p>
      {% endif %}

      <p class="trust"><span class="dot"></span>
        Paid straight into {{ config.business_name }}'s Monnify (Moniepoint) account.
        Marked paid only after Monnify confirms the money.</p>
    </section>

    <footer class="foot"><span>Generated by Monnify Studio</span></footer>
  </main>

  {% if invoice.status.value != "verified" %}
  <script>
    const status = document.getElementById("status");
    const pay = document.getElementById("pay");
    pay.addEventListener("click", async () => {
      pay.disabled = true;
      status.textContent = "Opening secure checkout...";
      try {
        const res = await fetch(
          "/preview/{{ artifact_id }}/invoice/{{ invoice.reference }}/pay",
          { method: "POST" });
        if (!res.ok) throw new Error(await res.text());
        const data = await res.json();
        window.open(data.checkout_url, "_blank");
        status.textContent = "Checkout opened in a new tab. After paying, come back here.";
      } catch (e) {
        status.textContent = "Could not start checkout. Try again.";
      } finally { pay.disabled = false; }
    });
    document.getElementById("claim").addEventListener("click", async () => {
      status.textContent = "Checking with Monnify...";
      try {
        const res = await fetch(
          "/preview/{{ artifact_id }}/orders/{{ invoice.reference }}/verify",
          { method: "POST" });
        const order = await res.json();
        if (order.status === "verified") { location.reload(); return; }
        status.textContent = order.note || "No confirmed payment yet.";
      } catch { status.textContent = "Could not check right now. Try again."; }
    });
  </script>
  {% endif %}
</body>
</html>
