<!doctype html>
{# The buyer-facing shop (#91, D17). The seller shares one link (WhatsApp bio,
   IG bio, printed QR); the buyer picks items and we generate an invoice. No
   login, big taps, Naira formatting, plain words. "Paid" only ever means
   Monnify confirmed it. #}
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ config.business_name }} — Order</title>
  <style>
    :root {
      --ink:#14201b; --muted:#5f6a63; --line:#e6eae6; --accent:{{ config.accent_color }};
      --paper:#f4f7f4; --card:#ffffff; --accent-soft:color-mix(in srgb, {{ config.accent_color }} 10%, #fff);
    }
    * { box-sizing:border-box; }
    body { margin:0; background:var(--paper); color:var(--ink);
      font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
      -webkit-font-smoothing:antialiased; }
    .shop { max-width:460px; margin:0 auto; min-height:100vh; background:var(--card);
      display:flex; flex-direction:column; box-shadow:0 0 60px rgba(20,32,27,.06); }
    .head { display:flex; gap:14px; align-items:center; padding:24px 20px 16px; }
    .mark { width:52px; height:52px; border-radius:15px; background:var(--accent); color:#fff;
      display:grid; place-items:center; font-weight:800; font-size:1.4rem; flex:0 0 auto; }
    .brand-logo { max-height:52px; max-width:160px; }
    .head h1 { margin:0; font-size:1.25rem; letter-spacing:-.01em; }
    .head p { margin:2px 0 0; color:var(--muted); font-size:.86rem; }
    .prompt { padding:6px 20px 14px; color:var(--muted); font-size:.92rem; }
    .items { list-style:none; margin:0; padding:0 12px 140px; flex:1 1 auto; }
    .item { display:flex; align-items:center; gap:12px; padding:16px 8px; border-bottom:1px solid var(--line); }
    .item:last-child { border-bottom:0; }
    .item .info { flex:1 1 auto; min-width:0; }
    .item .info b { display:block; font-weight:600; font-size:1rem; }
    .item .info small { color:var(--muted); font-variant-numeric:tabular-nums; }
    .add { appearance:none; border:1.5px solid var(--accent); background:transparent; color:var(--accent);
      font:inherit; font-weight:700; padding:10px 20px; border-radius:12px; cursor:pointer; }
    .add:active { transform:scale(.96); }
    .stepper { display:flex; align-items:center; gap:14px; }
    .stepper button { width:36px; height:36px; border-radius:10px; border:1px solid var(--line);
      background:var(--card); color:var(--ink); font-size:1.2rem; cursor:pointer; line-height:1; }
    .stepper b { min-width:16px; text-align:center; font-variant-numeric:tabular-nums; }
    .bar { position:fixed; left:0; right:0; bottom:0; }
    .bar-inner { max-width:460px; margin:0 auto; padding:14px 16px calc(16px + env(safe-area-inset-bottom));
      background:var(--card); border-top:1px solid var(--line); }
    .name-field { width:100%; padding:13px 15px; border:1px solid var(--line); border-radius:12px;
      font:inherit; margin-bottom:10px; background:var(--paper); color:inherit; }
    .cta { width:100%; appearance:none; border:0; border-radius:14px; background:var(--accent); color:#fff;
      font:inherit; font-weight:750; font-size:1.05rem; padding:16px; cursor:pointer;
      display:flex; align-items:center; justify-content:center; gap:10px; }
    .cta:disabled { opacity:.4; cursor:not-allowed; }
    .cta:active:not(:disabled) { transform:translateY(1px); }
    .cta .amt { font-variant-numeric:tabular-nums; }
    .trust { text-align:center; color:var(--muted); font-size:.76rem; margin:10px 4px 0; }
    .trust b { color:var(--accent); }
  </style>
</head>
<body>
  <main class="shop">
    <header class="head">
      {% if config.logo_url %}
      <img class="brand-logo" src="{{ config.logo_url }}" alt="{{ config.business_name }} logo" />
      {% else %}
      <div class="mark">{{ config.business_name[:1] }}</div>
      {% endif %}
      <div>
        <h1>{{ config.business_name }}</h1>
        <p>{{ config.tagline }}</p>
      </div>
    </header>
    <p class="prompt">Pick what you need. We'll make your invoice.</p>

    <ul class="items" id="items">
      {% for it in items %}
      <li class="item">
        <div class="info"><b>{{ it.name }}</b><small>NGN {{ it.price }}</small></div>
        <div class="ctrl" data-id="{{ it.id }}" data-price="{{ it.price_raw }}" data-name="{{ it.name }}"></div>
      </li>
      {% endfor %}
    </ul>

    <div class="bar">
      <div class="bar-inner">
        <input class="name-field" id="customer" placeholder="Your name (so they know who ordered)" />
        <button class="cta" id="checkout" disabled>
          <span>Get my invoice</span><span class="amt" id="total"></span>
        </button>
        <p class="trust">Every payment is <b>verified with Monnify</b>. No screenshots, no guessing.</p>
      </div>
    </div>
  </main>

  <script>
    const naira = (n) => "NGN " + n.toLocaleString("en-NG", { minimumFractionDigits: 2 });
    const cart = {};
    const meta = {};
    document.querySelectorAll(".ctrl").forEach((host) => {
      const id = host.dataset.id;
      meta[id] = { name: host.dataset.name, price: parseFloat(host.dataset.price) };
      render(id);
    });
    function render(id) {
      const host = document.querySelector('.ctrl[data-id="' + id + '"]');
      const q = cart[id] || 0;
      if (!q) {
        host.innerHTML = '<button class="add">Add</button>';
        host.querySelector(".add").onclick = () => { cart[id] = 1; render(id); total(); };
      } else {
        host.innerHTML = '<div class="stepper"><button aria-label="less">–</button><b>' + q +
          '</b><button aria-label="more">+</button></div>';
        const b = host.querySelectorAll("button");
        b[0].onclick = () => { cart[id] = Math.max(0, q - 1); if (!cart[id]) delete cart[id]; render(id); total(); };
        b[1].onclick = () => { cart[id] = q + 1; render(id); total(); };
      }
    }
    function sum() { return Object.keys(cart).reduce((a, id) => a + cart[id] * meta[id].price, 0); }
    function total() {
      const s = sum();
      document.getElementById("checkout").disabled = s === 0;
      document.getElementById("total").textContent = s ? "· " + naira(s) : "";
    }
    total();
    document.getElementById("checkout").onclick = async (e) => {
      const btn = e.currentTarget;
      btn.disabled = true;
      const selections = Object.keys(cart).map((id) => ({ id, qty: cart[id] }));
      try {
        const res = await fetch("/preview/{{ artifact_id }}/shop/invoice", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ customer: document.getElementById("customer").value, selections }),
        });
        if (!res.ok) throw new Error(await res.text());
        const data = await res.json();
        window.location.href = data.invoice_url;
      } catch (err) {
        btn.disabled = false;
        alert("Could not build your invoice. Please try again.");
      }
    };
  </script>
</body>
</html>
